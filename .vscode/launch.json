{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Laravel Artisan Serve",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend-laravel",
      "runtimeExecutable": "C:\\xampp\\php\\php.exe",
      "runtimeArgs": [
        "artisan",
        "serve"
      ],
      "console": "integratedTerminal",
      "presentation": {
        "group": "lumbarong",
        "order": 1
      }
    },
    {
      "name": "Vite Assets (CSS/JS)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend-laravel",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "console": "integratedTerminal",
      "presentation": {
        "group": "lumbarong",
        "order": 2
      }
    },
    {
      "name": "Launch Browser",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}/backend-laravel/public",
      "preLaunchTask": "Launch LumBarong",
      "presentation": {
        "group": "lumbarong",
        "order": 3
      }
    }
  ]
}