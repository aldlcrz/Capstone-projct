{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend Server (Laravel)",
      "type": "php",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend_laravel",
      "program": "${workspaceFolder}/backend_laravel/artisan",
      "runtimeExecutable": "C:\\xampp\\php\\php.exe",
      "runtimeArgs": [
        "serve"
      ],
      "presentation": {
        "group": "lumbarong",
        "order": 1
      }
    },
    {
      "name": "Frontend Server (Next.js)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "console": "integratedTerminal",
      "presentation": {
        "group": "lumbarong",
        "order": 2
      }
    },
    {
      "name": "Launch Lumbarong",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/frontend",
      "preLaunchTask": "Launch System",
      "presentation": {
        "group": "lumbarong",
        "order": 3
      }
    }
  ]
}